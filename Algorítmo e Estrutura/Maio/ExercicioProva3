# include <stdio.h>
# include <stdlib.h>
# define CAPACITY 100
# define TRUE 1
# define FALSE 0

typedef struct
 {
   int values[CAPACITY];
   int topA;
   int topB;
 } TwoStacks;
void initialize(TwoStacks *twoStacks)
 {
// TODO : implement this function.
    twoStacks->topA = CAPACITY;
    twoStacks->topB = -1;
 }
int isEmpty(TwoStacks *twoStacks)
 {
// TODO : implement this function.
    return twoStacks->topA == CAPACITY && twoStacks->topB == -1;
 }
int isFull(TwoStacks *twoStacks)
 {
// TODO : implement this function.
    //return twoStacks->topA == CAPACITY + 1 && twoStacks->topB == CAPACITY -1;
    return twoStacks->topA == twoStacks->topB;
 }
int push(TwoStacks *twoStacks, int values, int isA)
 {
    if(isFull(twoStacks))
    {
        printf("ERRO: a pilha esta cheia.\n");
        return 0;
    }
    
    if(isA == TRUE)
    {
      twoStacks->values[--twoStacks->topA] = values;
    }
    else
    {
      twoStacks->values[++twoStacks->topB] = values;
    }

    return 1;
 }
int pop(TwoStacks *twoStacks, int isA)
 {
    if (isA == TRUE)
    {
      return twoStacks->values[twoStacks->topA--];
    }
    else
    {
      return twoStacks->values[twoStacks->topB++];
    }
 }
int main()
 {
   TwoStacks twoStacks;
   initialize(&twoStacks);
   push(&twoStacks, 10, TRUE);
   push(&twoStacks, 20, TRUE);
   push(&twoStacks, 30, FALSE);
   push(&twoStacks, 40, FALSE);
   push(&twoStacks, 50, TRUE);
   pop(&twoStacks, FALSE);
 }
