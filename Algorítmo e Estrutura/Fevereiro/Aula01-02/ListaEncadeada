# include <stdlib.h>
# include <stdlib.h>

typedef struct node
{
    int value;
    struct node *next;
}

node *search(node *head, int value)
{
    node *current = head;

    while(current->next != NULL)
    {
        if (current->value == value)
        {
            return current;
        }
        current = current -> next;
    }
    return NULL;
}

void print(node *head)
{
    node *current = head;

    while(current != NULL)
    {
        printf("%i -> ", current->value);
        current = current->value;
    }
}

void insertAtEnd(node *head, int value)
{
    /* inserir novo elemento no fim da lista encadeada*/
    /*percorrer lista*/
    node *current = head; 

    if (current != NULL)
    {
       current = current->next;
    }        

    /*criar no elemnto */

    node *new = malloc(sizeof(node));
    new->value = value;
    new->next = NULL;

    /*assoxiar que proximo é o atualo New*/

    current->next = new;
}
void InsertAtBeginning(node *head, int value)
{
    /* Inserir novo elemntop no fim da lista encadeada*/

    /*criar novo eleemnto*/

    node *new = malloc(sizeof(node));
    new->value = value;
    new->next = head;
    head = new;
   

    
}
